# Copy this file to .env and fill in real values:  cp .env-template .env
# .env is gitignored — never commit it.

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=notes_app

# HTTP server port
SERVER_PORT=8080

# JWT signing secret — generate a real one with:  openssl rand -base64 48
JWT_SECRET=
